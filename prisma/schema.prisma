// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String
  email     String?  @unique
  password  String?
  emailVerified DateTime?
  createdAt DateTime @default(now())

  topics      Topic[]
  memberships Membership[]
  opinions    Opinion[]
  transactions Transaction[]
  purchases   Purchase[]
  // tickets     Int      @default(0) // Deprecated: Use Purchase.remainingTickets

  eyesCount         Int      @default(10)
  trashCount        Int      @default(10)
  lastReplenishedAt DateTime @default(now())
  
  opinionVotes      OpinionVote[]

  role              Role     @default(USER)
}

enum Role {
  USER
  ADMIN
}

model TicketPackage {
  id          String   @id @default(uuid())
  name        String
  description String?
  ticketCount Int
  price       Float
  duration    Int      // Duration in hours
  cooldown    Int      // Cooldown in hours
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VotePackage {
  id          String   @id @default(uuid())
  cost        Int      // Tickets needed
  value       Int      // Votes added
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SystemSetting {
  key         String   @id
  value       String   // Store values as string (parse as needed)
  description String?
  updatedAt   DateTime @updatedAt
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  packageId String   // 'daily', 'weekly', 'monthly'
  amount    Float    // Price
  tickets   Int      // Initial Tickets
  remainingTickets Int // Remaining tickets
  expiresAt DateTime // Expiration time
  provider  String   @default("lemonsqueezy")
  providerOrderId String? @unique
  createdAt DateTime @default(now())
}

model Topic {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  
  isPrivate   Boolean  @default(false)
  password    String?
  roomCode    String?  @unique // Unique code for private topics (e.g., "839201")

  seekBrainstorming Boolean @default(false)
  seekRational      Boolean @default(false)

  totalValue        Int      @default(0) // Cache for sorting: sum of all factions' (members + paid votes)
  
  factions    Faction[]
  memberships Membership[] // Helper to track user participation in topic
}

model Faction {
  id          String   @id @default(uuid())
  name        String
  description String?
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  createdAt   DateTime @default(now())

  seekBrainstorming Boolean @default(false)
  seekRational      Boolean @default(false)
  
  paidVoteCount     Int      @default(0)
  lastZeroedAt      DateTime? // Tracks when (members + paidVoteCount) became 0

  members     Membership[]
  opinions    Opinion[]
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  factionId String
  faction   Faction  @relation(fields: [factionId], references: [id])
  amount    Float
  votes     Int
  createdAt DateTime @default(now())
}

model Membership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  factionId String?
  faction   Faction? @relation(fields: [factionId], references: [id], onDelete: SetNull)
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([userId, topicId]) // Ensures a user can only join one faction per topic
}

model Opinion {
  id        String   @id @default(uuid())
  summary   String
  detail    String?
  type      ReasonType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  
  factionId String
  faction   Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)
  
  // Citations
  citedBy   Citation[] @relation("TargetOpinion")
  citations Citation[] @relation("SourceOpinion")
  
  // Layout Logic: Neighbor preference (Physics only, not semantic hierarchy)
  neighborId String?
  neighbor   Opinion?   @relation("OpinionNeighbors", fields: [neighborId], references: [id])
  neighbors  Opinion[]  @relation("OpinionNeighbors")

  eyes       Int      @default(0)
  trash      Int      @default(0)
  votes      OpinionVote[]

  @@unique([authorId, factionId, type]) // Ensures one opinion per type per faction for a user
}

model Citation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  sourceId  String
  source    Opinion  @relation("SourceOpinion", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId  String
  target    Opinion  @relation("TargetOpinion", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId]) // Prevent duplicate citations
}

enum ReasonType {
  WHY
  WHY_NOT
}

model OpinionVote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  opinionId String
  opinion   Opinion  @relation(fields: [opinionId], references: [id], onDelete: Cascade)
  type      VoteType
  createdAt DateTime @default(now())

  @@unique([userId, opinionId])
}

enum VoteType {
  EYE
  TRASH
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
